{
  "name": "stackhealth",
  "private": true,
  "scripts": {
    "dev:web": "turbo run dev --filter=@stackhealth/web",
    "dev:mobile": "turbo run dev --filter=@stackhealth/mobile",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@stackhealth/eslint-config": "workspace:*",
    "@stackhealth/typescript-config": "workspace:*",
    "prettier": "^3.2.5",
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
